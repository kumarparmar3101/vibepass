{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and settings",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "Firebase Auth UID"
        },
        "name": {
          "type": "string",
          "description": "User's display name"
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "User's email address"
        },
        "avatarUrl": {
          "type": "string",
          "description": "URL to user's profile picture"
        },
        "city": {
          "type": "string",
          "description": "User's selected city for events"
        },
        "isOnboarded": {
          "type": "boolean",
          "description": "Whether the user has completed onboarding"
        },
        "createdAt": {
          "type": "timestamp",
          "description": "When the user account was created"
        }
      },
      "required": ["uid", "name", "email", "createdAt"]
    },
    "Order": {
      "title": "Order",
      "description": "Ticket booking order",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "Firebase Auth UID of the user who made the order"
        },
        "eventId": {
          "type": "string",
          "description": "ID of the event/movie"
        },
        "seats": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Selected seats"
        },
        "totalAmount": {
          "type": "number",
          "description": "Total amount paid"
        },
        "ticketPrice": {
          "type": "number",
          "description": "Price of tickets"
        },
        "convenienceFee": {
          "type": "number",
          "description": "Convenience fee"
        },
        "donation": {
          "type": "number",
          "description": "Donation amount"
        },
        "status": {
          "type": "string",
          "description": "Order status"
        },
        "paymentMethod": {
          "type": "string",
          "description": "Payment method used"
        },
        "createdAt": {
          "type": "timestamp",
          "description": "When the order was created"
        }
      },
      "required": ["userId", "eventId", "seats", "totalAmount", "ticketPrice", "convenienceFee", "donation", "status", "paymentMethod", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": {
        "$ref": "#/entities/User"
      },
      "description": "Stores user profiles and their settings"
    }
  }
}
